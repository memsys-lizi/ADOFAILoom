<Project>

  <PropertyGroup>
    <GameDir Condition="'$(GameExePath)' != ''">$([System.IO.Path]::GetDirectoryName($(GameExePath)))</GameDir>
    <GameFileName Condition="'$(GameExePath)' != ''">$([System.IO.Path]::GetFileNameWithoutExtension($(GameExePath)))</GameFileName>
    <PathSeparator>$([System.IO.Path]::DirectorySeparatorChar)</PathSeparator>
    <ManagedAssembliesDir Condition="'$(GameExePath)' != ''">$(GameDir)$(PathSeparator)$(GameFileName)_Data$(PathSeparator)Managed</ManagedAssembliesDir>
    <RepositoryRoot>$([System.IO.Path]::GetFullPath('$(MSBuildProjectDirectory)\..\..'))</RepositoryRoot>
    <PackageRoot>$(RepositoryRoot)$(PathSeparator)out$(PathSeparator)</PackageRoot>
    <PackageDir>$(PackageRoot)$(AssemblyName)$(PathSeparator)</PackageDir>
  </PropertyGroup>

  <Target Name="ValidateGameExePath" BeforeTargets="ResolveAssemblyReferences">
    <Error Text="未设置游戏路径。请设置 ADOFAI_GAME_EXE 环境变量、ADOFAILoom.local.props 或 GameExePath。/ Game executable path is not configured."
           Condition="'$(GameExePath)' == ''" />
    <Error Text="游戏可执行文件不存在：$(GameExePath)。/ Game executable does not exist: $(GameExePath)."
           Condition="'$(GameExePath)' != '' AND !Exists('$(GameExePath)')" />
    <Error Text="游戏 Managed 目录不存在：$(ManagedAssembliesDir)。/ Game Managed directory does not exist: $(ManagedAssembliesDir)."
           Condition="'$(GameExePath)' != '' AND !Exists('$(ManagedAssembliesDir)')" />
  </Target>

  <Target Name="PackageMod" AfterTargets="Build">
    <RemoveDir Directories="$(PackageRoot)" />
    <MakeDir Directories="$(PackageDir)" />
    <ItemGroup>
      <PackageFiles Include="$(TargetPath)" />
      <PackageFiles Include="$(MSBuildProjectDirectory)$(PathSeparator)Info.json" />
    </ItemGroup>
    <Copy SourceFiles="@(PackageFiles)" DestinationFolder="$(PackageDir)" />
    <Message Text="Installable Mod package: $(PackageDir)" Importance="high" />
  </Target>

  <Target Name="DeployAndLaunch"
          AfterTargets="PackageMod"
          Condition="'$(DeployMod)' == 'true'">
    <PropertyGroup>
      <ModsDir>$(GameDir)$(PathSeparator)Mods$(PathSeparator)$(AssemblyName)$(PathSeparator)</ModsDir>
    </PropertyGroup>

    <RemoveDir Directories="$(ModsDir)" />
    <MakeDir Directories="$(ModsDir)" />
    <ItemGroup>
      <ModPackageFiles Include="$(PackageDir)**$(PathSeparator)*" />
    </ItemGroup>
    <Copy SourceFiles="@(ModPackageFiles)"
          DestinationFiles="@(ModPackageFiles->'$(ModsDir)%(RecursiveDir)%(Filename)%(Extension)')" />
    <Message Text="Mod deployed to game directory: $(ModsDir)" Importance="high" />

    <Exec Command="start &quot;&quot; &quot;$(GameExePath)&quot;"
          IgnoreExitCode="true"
          Condition="'$(AutoLaunchGame)' == 'true' AND '$(OS)' == 'Windows_NT'" />
    <Message Text="Game launched: $(GameExePath)" Importance="high"
             Condition="'$(AutoLaunchGame)' == 'true'" />
  </Target>

</Project>
